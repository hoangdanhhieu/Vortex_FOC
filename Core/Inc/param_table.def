/**
 * @file param_table.def
 * @brief X-Macro table for all configurable parameters in the FOC system.
 * 
 * This file serves as the Single Source of Truth for parameter definitions.
 * It is used to automatically generate struct fields, Enums, Default assignments,
 * and Pointer mapping arrays, eliminating copy-paste errors across the project.
 *
 * Format:
 * PARAM_DEF(ENUM_ID,     data_type, struct_name,          default_macro)
 */

#ifndef PARAM_DEF
#error "PARAM_DEF macro must be defined before including this file"
#endif

/* Current PI */
PARAM_DEF(PID_KP_ID,      float,     kp_id,                PI_ID_KP)
PARAM_DEF(PID_KI_ID,      float,     ki_id,                PI_ID_KI)
PARAM_DEF(PID_KP_IQ,      float,     kp_iq,                PI_IQ_KP)
PARAM_DEF(PID_KI_IQ,      float,     ki_iq,                PI_IQ_KI)
PARAM_DEF(PID_BW_CUR,     float,     bw_cur,               CURRENT_LOOP_BW)

/* Speed PI */
PARAM_DEF(PID_KP_SPD,     float,     kp_spd,               PI_SPEED_KP)
PARAM_DEF(PID_KI_SPD,     float,     ki_spd,               PI_SPEED_KI)
PARAM_DEF(PID_BW_SPD,     float,     bw_spd,               SPEED_LOOP_BW)

/* Startup */
PARAM_DEF(PID_I_STRT,     float,     startup_current,      STARTUP_CURRENT)
PARAM_DEF(PID_I_ALGN,     float,     align_current,        ALIGN_CURRENT)
PARAM_DEF(PID_ACCEL,      float,     startup_accel,        STARTUP_ACCEL)
PARAM_DEF(PID_HANDOFF,    float,     startup_handoff_speed,STARTUP_HANDOFF_SPEED)

/* Ramp Rates */
PARAM_DEF(PID_RAMP_ACC,   float,     speed_ramp_accel,     SPEED_RAMP_ACCEL)
PARAM_DEF(PID_RAMP_DEC,   float,     speed_ramp_decel,     SPEED_RAMP_DECEL)
PARAM_DEF(PID_I_RAMP,     float,     current_ramp_rate,    CURRENT_RAMP_RATE)

/* Motor */
PARAM_DEF(PID_M_RS,       float,     motor_rs,             MOTOR_RS)
PARAM_DEF(PID_M_LS,       float,     motor_ls,             MOTOR_LS)
PARAM_DEF(PID_M_KV,       float,     motor_kv,             MOTOR_KV)
PARAM_DEF(PID_M_FLUX,     float,     motor_flux,           MOTOR_FLUX_LINKAGE)
PARAM_DEF(PID_M_POLES,    float,     motor_poles,          (float)MOTOR_POLE_PAIRS)
PARAM_DEF(PID_M_MAX_SPD,  float,     motor_max_spd,        MOTOR_MAX_SPEED_RPM)
PARAM_DEF(PID_M_MIN_SPD,  float,     motor_min_spd,        MOTOR_MIN_SPEED_RPM)
PARAM_DEF(PID_M_MAX_I,    float,     motor_max_curr,       MOTOR_MAX_CURRENT)

/* SMO */
PARAM_DEF(PID_SMO_KS,     float,     smo_k_slide,          SMO_K_SLIDE)
PARAM_DEF(PID_SMO_SIG,    float,     smo_k_sigmoid,        SMO_K_SIGMOID)
PARAM_DEF(PID_SMO_PLL,    float,     smo_pll_cutoff,       SMO_PPL_CUTOFF)
PARAM_DEF(PID_COMP_DELAY, float,     comp_delay_samples,   COMP_DELAY_SAMPLES)

PARAM_DEF(PID_ADC_MARG,   float,     adc_margin_ticks,     ADC_MARGIN_DEFAULT)
PARAM_DEF(PID_ADC_FILT_A, float,     adc_filt_a,           CURRENT_FILTER_ALPHA)
PARAM_DEF(PID_DQ_FILT_A,  float,     dq_filt_a,            FOC_DQ_FILTER_ALPHA)

/* Safety */
PARAM_DEF(PID_OC_THR,     float,     fault_oc_threshold,   FAULT_OVERCURRENT_THRESHOLD)
PARAM_DEF(PID_OV_THR,     float,     fault_ov_threshold,   FAULT_OVERVOLTAGE_THRESHOLD)
PARAM_DEF(PID_UV_THR,     float,     fault_uv_threshold,   FAULT_UNDERVOLTAGE_THRESHOLD)
PARAM_DEF(PID_STALL_SPD,  float,     fault_stall_speed,    FAULT_STALL_SPEED_RPM)
PARAM_DEF(PID_STALL_I,    float,     fault_stall_current,  FAULT_STALL_CURRENT_A)
PARAM_DEF(PID_STALL_MS,   float,     fault_stall_time_ms,  FAULT_STALL_TIME_MS)


/* Internal Non-GUI params */
PARAM_DEF(PID_DIRECTION,  int8_t,    direction,            1)
PARAM_DEF(PID_OC_COUNT,   uint8_t,   fault_oc_count,       FAULT_OVERCURRENT_COUNT)
PARAM_DEF(PID_STALL_EN,   uint8_t,   fault_stall_enable,   FAULT_STALL_ENABLE)

/* Undefine the macro so the file can be included multiple times with different definitions */
#undef PARAM_DEF
